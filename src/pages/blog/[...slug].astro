---
import { render } from 'astro:content';
import NewsletterSubscribe from '../../components/NewsletterSubscribe.astro';
import { getPublishedBlogPosts } from '../../data/blog';
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';
import {
    absoluteAssetUrl,
    absoluteUrl,
    blogPostOgImagePath,
    blogPostPath,
} from '../../lib/seo';

type BlogPost = Awaited<ReturnType<typeof getPublishedBlogPosts>>[number];
type Props = {
    post: BlogPost;
};

export async function getStaticPaths() {
    const posts = await getPublishedBlogPosts();

    return posts.map((post: BlogPost) => ({
        params: { slug: post.data.post_slug },
        props: { post },
    }));
}

const { post } = Astro.props as Props;
const { Content } = await render(post);
const canonicalPath = blogPostPath(post.data.post_slug);
const ogImage = blogPostOgImagePath(post.data.post_slug);
const datePublished = post.data.publish_date.toISOString();
const dateModified = (post.data.updated_date ?? post.data.publish_date).toISOString();
const postJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    url: absoluteUrl(canonicalPath),
    image: absoluteAssetUrl(ogImage),
    datePublished,
    dateModified,
    author: post.data.author.map((name) => ({
        '@type': 'Person',
        name,
        url: absoluteUrl('/'),
    })),
    publisher: {
        '@type': 'Person',
        name: site.author,
        url: absoluteUrl('/'),
    },
    keywords: post.data.tags,
    inLanguage: post.data.lang,
    mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': absoluteUrl(canonicalPath),
    },
};
const breadcrumbJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: site.name,
            item: absoluteUrl('/'),
        },
        {
            '@type': 'ListItem',
            position: 2,
            name: 'Blog',
            item: absoluteUrl('/blog'),
        },
        {
            '@type': 'ListItem',
            position: 3,
            name: post.data.title,
            item: absoluteUrl(canonicalPath),
        },
    ],
};

const formatDate = (date: Date) =>
    new Intl.DateTimeFormat(post.data.lang || 'en', {
        year: 'numeric',
        month: 'short',
        day: '2-digit',
    }).format(date);
---

<Layout
    title={`${post.data.title} | ${site.name}`}
    description={post.data.description}
    lang={post.data.lang}
    canonicalPath={canonicalPath}
    image={ogImage}
    imageAlt={`${post.data.title} social image`}
    type="article"
    publishedTime={datePublished}
    modifiedTime={dateModified}
    authors={post.data.author}
    tags={post.data.tags}
    jsonLd={[postJsonLd, breadcrumbJsonLd]}
>
    <article class="blog-post border-t border-border px-6 py-16 text-text sm:px-10 sm:py-20">
        <div class="blog-post-shell space-y-12">
            <header class="space-y-6">
                <a
                    class="inline-flex font-mono text-sm uppercase tracking-[0.16em] text-primary underline decoration-border underline-offset-4 transition-colors hover:decoration-primary focus-visible:decoration-primary focus-visible:outline-none"
                    href="/blog/"
                >
                    /blog
                </a>

                <div class="space-y-5">
                    <h1 class="text-3xl font-bold leading-tight text-text sm:text-5xl">
                        {post.data.title}
                    </h1>
                    <p class="blog-copy max-w-3xl text-lg leading-8 text-text/70">
                        {post.data.description}
                    </p>
                </div>

                <div class="flex flex-wrap gap-x-5 gap-y-3 font-mono text-sm uppercase tracking-[0.12em] text-text/60">
                    <span>{post.data.author.join(', ')}</span>
                    <time datetime={post.data.publish_date.toISOString()}>
                        {formatDate(post.data.publish_date)}
                    </time>
                    {post.data.updated_date && <span>Updated {formatDate(post.data.updated_date)}</span>}
                </div>

                <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag: string) => (
                        <span class="border border-border px-2 py-1 font-mono text-xs uppercase tracking-[0.12em] text-text/60">
                            #{tag}
                        </span>
                    ))}
                </div>
            </header>

            <div class="markdown-content">
                <Content />
            </div>
        </div>

        <div class="blog-post-newsletter">
            <NewsletterSubscribe />
        </div>
    </article>

    <div
        class="blog-image-lightbox"
        data-blog-image-lightbox
        role="dialog"
        aria-modal="true"
        aria-label="Expanded blog image"
        hidden
    >
        <button
            class="blog-image-lightbox-close"
            type="button"
            data-blog-image-lightbox-close
            aria-label="Close expanded image"
        >
            Close
        </button>
        <img class="blog-image-lightbox-image" data-blog-image-lightbox-image alt="" />
    </div>

    <script>
        const markdownImages = Array.from(
            document.querySelectorAll('.markdown-content img'),
        );
        const lightbox = document.querySelector('[data-blog-image-lightbox]');
        const lightboxImage = document.querySelector('[data-blog-image-lightbox-image]');
        const closeButton = document.querySelector('[data-blog-image-lightbox-close]');
        let activeImage: HTMLImageElement | null = null;
        let closeTimer = 0;
        let previousBodyOverflow = '';

        const closeLightbox = () => {
            if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) {
                return;
            }

            lightbox.dataset.state = 'closing';

            window.clearTimeout(closeTimer);
            closeTimer = window.setTimeout(() => {
                lightbox.hidden = true;
                lightboxImage.removeAttribute('src');
                lightboxImage.alt = '';
                delete lightbox.dataset.state;
                document.body.style.overflow = previousBodyOverflow;

                if (activeImage instanceof HTMLElement) {
                    activeImage.focus();
                }

                activeImage = null;
            }, 180);
        };

        const openLightbox = (image: HTMLImageElement) => {
            if (
                !(image instanceof HTMLImageElement) ||
                !(lightbox instanceof HTMLElement) ||
                !(lightboxImage instanceof HTMLImageElement)
            ) {
                return;
            }

            window.clearTimeout(closeTimer);
            activeImage = image;
            previousBodyOverflow = document.body.style.overflow;
            lightboxImage.src = image.currentSrc || image.src;
            lightboxImage.alt = image.alt;
            lightbox.dataset.state = 'opening';
            lightbox.hidden = false;
            document.body.style.overflow = 'hidden';

            window.requestAnimationFrame(() => {
                lightbox.dataset.state = 'open';
            });

            if (closeButton instanceof HTMLElement) {
                closeButton.focus();
            }
        };

        markdownImages.forEach((image) => {
            if (!(image instanceof HTMLImageElement)) {
                return;
            }

            image.tabIndex = 0;
            image.role = 'button';
            image.setAttribute('aria-label', image.alt ? `Expand image: ${image.alt}` : 'Expand image');

            image.addEventListener('click', () => openLightbox(image));
            image.addEventListener('keydown', (event) => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    openLightbox(image);
                }
            });
        });

        closeButton?.addEventListener('click', closeLightbox);
        lightboxImage?.addEventListener('click', closeLightbox);

        lightbox?.addEventListener('click', (event) => {
            if (event.target === lightbox) {
                closeLightbox();
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && lightbox instanceof HTMLElement && !lightbox.hidden) {
                closeLightbox();
            }
        });
    </script>
</Layout>

<style>
    .blog-post-shell {
        width: min(100%, 48rem);
        margin: 0 auto;
    }

    .blog-post-newsletter {
        width: min(100%, 64rem);
        margin: 4rem auto 0;
    }

    .blog-ssh-copy:focus-visible {
        outline: 1px solid var(--color-primary);
        outline-offset: -1px;
    }

    .blog-copy {
        font-family: "Inter", var(--font-sans);
    }

    .markdown-content {
        color: var(--color-text);
        font-family: "Inter", var(--font-sans);
        font-size: 1.0625rem;
        line-height: 1.8;
    }

    .markdown-content :global(*) {
        overflow-wrap: break-word;
    }

    .markdown-content :global(h1),
    .markdown-content :global(h2),
    .markdown-content :global(h3),
    .markdown-content :global(h4),
    .markdown-content :global(h5),
    .markdown-content :global(h6) {
        font-family: var(--font-sans);
        color: var(--color-text);
        font-weight: 700;
        line-height: 1.2;
        margin: 2.5rem 0 1rem;
    }

    .markdown-content :global(h1) {
        font-size: 2.25rem;
    }

    .markdown-content :global(h2) {
        font-size: 1.875rem;
    }

    .markdown-content :global(h3) {
        font-size: 1.5rem;
    }

    .markdown-content :global(h4) {
        font-size: 1.25rem;
    }

    .markdown-content :global(h5) {
        font-size: 1.125rem;
    }

    .markdown-content :global(h6) {
        font-size: 1rem;
    }

    .markdown-content :global(p),
    .markdown-content :global(ul),
    .markdown-content :global(ol),
    .markdown-content :global(blockquote),
    .markdown-content :global(pre),
    .markdown-content :global(img),
    .markdown-content :global(table) {
        margin: 1.25rem 0;
    }

    .markdown-content :global(a) {
        color: var(--color-text);
        text-decoration: underline;
        text-decoration-color: color-mix(in srgb, var(--color-text) 48%, transparent);
        text-underline-offset: 0.25em;
        transition:
            color 180ms ease-out,
            text-decoration-color 180ms ease-out;
    }

    .markdown-content :global(a:hover),
    .markdown-content :global(a:focus-visible) {
        color: var(--color-primary);
        text-decoration-color: var(--color-primary);
        outline: none;
    }

    .markdown-content :global(ul),
    .markdown-content :global(ol) {
        padding-left: 1.4rem;
    }

    .markdown-content :global(ul) {
        list-style: disc;
    }

    .markdown-content :global(ol) {
        list-style: decimal;
    }

    .markdown-content :global(li::marker) {
        color: var(--color-primary);
    }

    .markdown-content :global(li + li) {
        margin-top: 0.45rem;
    }

    .markdown-content :global(code) {
        border: 1px solid var(--color-border);
        padding: 0.12rem 0.35rem;
        color: var(--color-primary);
        font-size: 0.92em;
    }

    .markdown-content :global(pre) {
        overflow-x: auto;
        border: 1px solid var(--color-border);
        padding: 0.65rem 0.75rem;
    }

    .markdown-content :global(pre code) {
        border: 0;
        padding: 0;
        color: inherit;
    }

    .markdown-content :global(blockquote) {
        border-left: 2px solid var(--color-primary);
        padding-left: 1rem;
        color: color-mix(in srgb, var(--color-text) 90%, transparent);
    }

    .markdown-content :global(table) {
        display: block;
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        border-collapse: collapse;
        font-size: 0.95rem;
        line-height: 1.55;
        white-space: nowrap;
    }

    .markdown-content :global(th),
    .markdown-content :global(td) {
        border: 1px solid var(--color-border);
        padding: 0.65rem 0.8rem;
        text-align: left;
        vertical-align: top;
    }

    .markdown-content :global(th) {
        background: color-mix(in srgb, var(--color-text) 8%, transparent);
        color: var(--color-text);
        font-weight: 700;
    }

    .markdown-content :global(tr:nth-child(even) td) {
        background: color-mix(in srgb, var(--color-text) 4%, transparent);
    }

    .markdown-content :global(img) {
        display: block;
        max-width: 100%;
        border: 1px solid var(--color-border);
        cursor: zoom-in;
        transition:
            border-color 180ms ease-out,
            opacity 180ms ease-out;
    }

    .markdown-content :global(img:hover),
    .markdown-content :global(img:focus-visible) {
        border-color: var(--color-primary);
        opacity: 0.92;
        outline: none;
    }

    .blog-image-lightbox {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: grid;
        place-items: center;
        padding: 4rem 1rem 1rem;
        background: color-mix(in srgb, var(--color-background) 88%, transparent);
        backdrop-filter: blur(10px);
        opacity: 0;
        transition: opacity 180ms ease-out;
    }

    .blog-image-lightbox[hidden] {
        display: none;
    }

    .blog-image-lightbox[data-state="open"] {
        opacity: 1;
    }

    .blog-image-lightbox-image {
        max-width: min(96vw, 100%);
        max-height: 88vh;
        border: 1px solid var(--color-border);
        object-fit: contain;
        background: var(--color-background);
        cursor: zoom-out;
        opacity: 0;
        transform: scale(0.96);
        transition:
            opacity 180ms ease-out,
            transform 180ms ease-out;
    }

    .blog-image-lightbox[data-state="open"] .blog-image-lightbox-image {
        opacity: 1;
        transform: scale(1);
    }

    .blog-image-lightbox-close {
        position: fixed;
        top: 1rem;
        right: 1rem;
        border: 1px solid var(--color-border);
        background: var(--color-background);
        padding: 0.65rem 0.8rem;
        color: var(--color-text);
        font-family: var(--font-sans);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        transition:
            border-color 180ms ease-out,
            color 180ms ease-out;
    }

    .blog-image-lightbox-close:hover,
    .blog-image-lightbox-close:focus-visible {
        border-color: var(--color-primary);
        color: var(--color-primary);
        outline: none;
    }

    @media (min-width: 800px) {
        .blog-image-lightbox {
            padding: 4.5rem 2rem 2rem;
        }

        .blog-image-lightbox-image {
            max-width: 94vw;
            max-height: 86vh;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .blog-image-lightbox,
        .blog-image-lightbox-image {
            transition: none;
        }
    }
</style>
